{
  "name": "maru-desktop-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "MARU Live Desktop monorepo — Electron + React UI, Python sidecar (TikTok/juegos/IA), shared types & UI",
  "license": "UNLICENSED",
  "author": "soykoru <maicolchia07@gmail.com>",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @maru/desktop dev",
    "dev:all": "turbo run dev",
    "dev:desktop": "pnpm --filter @maru/desktop dev",
    "dev:sidecar": "pnpm --filter @maru/sidecar dev",
    "build": "turbo run build",
    "build:desktop": "pnpm --filter @maru/desktop build",
    "build:sidecar": "pnpm --filter @maru/sidecar build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "pnpm --filter @maru/sidecar test",
    "test:sidecar": "pnpm --filter @maru/sidecar test",
    "quickcheck": "node scripts/quickcheck.mjs",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
