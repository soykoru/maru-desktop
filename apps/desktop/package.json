{
  "name": "@maru/desktop",
  "version": "1.0.12",
  "private": true,
  "license": "UNLICENSED",
  "description": "MARU Live Desktop — Electron + React",
  "author": "soykoru <maicolchia07@gmail.com>",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "cross-env NODE_ENV=production electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "echo \"lint placeholder F0\" && exit 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist out release .turbo *.tsbuildinfo",
    "pack": "electron-builder --win --x64 --publish never",
    "release": "electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "@maru/shared": "workspace:*",
    "@maru/ui": "workspace:*",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.460.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@maru/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
