# MARU Desktop — variables de entorno
# Copiá este archivo a `.env` y ajustá los valores. NO commitear `.env`.

# ── Sidecar Python ─────────────────────────────────────────────────────────
# Path al `LiveChaosEngine_Refactored/` original (default: ../../LiveChaosEngine/...)
# MARU_CORE_ROOT=C:\Users\User\Desktop\MARU PRO\LiveChaosEngine\LiveChaosEngine_Refactored

# Carpeta runtime del sidecar (data, logs, backups, profiles)
# Default dev: apps/sidecar/runtime_data
# Default prod: %APPDATA%/MARU Live (Windows)
# MARU_RUNTIME_DIR=

# Ejecutable Python a usar en dev (default: 'python')
# MARU_PYTHON=python

# Activar tracemalloc para profiling de memoria (overhead 10-20%)
# MARU_TRACEMALLOC=1


# ── Electron desktop ───────────────────────────────────────────────────────
# Forzar abrir DevTools en dev (default: cerradas)
# MARU_DEVTOOLS=1

# Forzar hardening de producción en dev (para QA pre-release)
# MARU_FORCE_HARDENING=1

# Desactivar el auto-updater explícitamente
# MARU_DISABLE_UPDATER=1


# ── Telemetría opcional ────────────────────────────────────────────────────
# Solo se usa si el usuario activa telemetría en Settings → Privacidad
# Y `@sentry/electron` está instalado.
# MARU_SENTRY_DSN=https://xxx@sentry.io/yyy


# ── Release pipeline ───────────────────────────────────────────────────────
# Token de GitHub con scope `repo` para publicar a Releases (privado o público)
# GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Skip publish (solo build local) — útil para smoke tests
# MARU_SKIP_PUBLISH=1
